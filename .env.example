# Copy to .env for local development. Dev defaults work out of the box with `npm run dev`
# (embedded Postgres). All values here are development-only placeholders.
# For production see docs/DEPLOY.md — the app needs only DATABASE_URL and derives
# its RLS-bound app_rw connection from it.

# App connection (non-owner role, RLS enforced)
DATABASE_URL=postgres://app_rw:app_rw_dev_pw@127.0.0.1:5433/gym_dev
# Owner connection (migrations + seeds only). Omit both this and the derived
# behaviour kicks in: DATABASE_URL is treated as the owner url.
DATABASE_ADMIN_URL=postgres://postgres:postgres@127.0.0.1:5433/gym_dev

PG_PORT=5433
API_PORT=3001
WEB_ORIGIN=http://localhost:5173

# 32-byte base64 key for app-layer encryption of sensitive columns (PAR-Q, injury notes).
# Generate for real environments: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SENSITIVE_DATA_KEY=ZGV2LW9ubHkta2V5LWRldi1vbmx5LWtleS1kZXYta2V5IQ==

# Local media storage directory (dev media adapter; Stream/R2 adapters take credentials later)
UPLOADS_DIR=./uploads
